<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!-- Only count the driver assembly toward coverage. -->
          <Include>[AdbcDrivers.HiveServer2]*</Include>
          <!-- Exclude the unmodified generated Thrift bindings: they're auto-
               generated, would dwarf the hand-written code in line counts,
               and aren't meaningful coverage targets. -->
          <Exclude>[AdbcDrivers.HiveServer2]Apache.Hive.Service.Rpc.Thrift.*</Exclude>
          <ExcludeByFile>**/Thrift/Service/Rpc/Thrift/**/*.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
